# =============================================================
#  .env raíz — Variables para `docker compose up`
#  Copia este archivo a `.env` y rellena los valores.
# =============================================================

# ----- Gemini (AI-component y frontend) -----
GOOGLE_API_KEY=tu_api_key_de_gemini
GEMINI_API_KEY=tu_api_key_de_gemini
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_de_gemini

# ----- Supabase (corre en el host vía `npx supabase start` dentro de db/) -----
# Obtén las llaves con: cd db && npx supabase status
#
# URL del host (vista desde dentro de los contenedores backend / ai-component):
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVER_URL=http://host.docker.internal:54321

# URL pública (vista desde el navegador del usuario):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Llaves de Supabase
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ----- Backend ↔ AI-component (rara vez necesitas tocarlos) -----
# Los siguientes ya se inyectan automáticamente desde el docker-compose.yml:
#   AI_COMPONENT_URL=http://ai-component:8001   (en backend)
#   FASTAPI_URL=http://backend:8000             (en ai-component)
#   FASTAPI_BASE_URL=http://backend:8000        (en frontend, SSR)
